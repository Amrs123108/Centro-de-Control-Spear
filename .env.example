# ── Centro de Control Spear · plantilla de variables de entorno ──────────────
# Copiar a .env.local y completar. En Vercel, configurar en Project Settings.

# Secreto para firmar las sesiones (generar uno propio):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Usuarios (JSON). rol: ADMIN | DIRECTIVO | GERENCIA
# Hash de contraseña:
#   node -e "console.log(require('crypto').createHash('sha256').update('MiClave').digest('hex'))"
CCS_USERS=[{"email":"usuario@spearcontact.com","nombre":"Nombre Apellido","rol":"ADMIN","password_sha256":"<hash>"}]
